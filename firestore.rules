rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Rankings (run results) — world-readable, authenticated writes only,
    // and the playerId on the record must equal the caller's uid.
    match /rankings/{runId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.playerId
        && isValidRanking();
      allow update, delete: if false;
    }

    // Player profiles — world-readable (so leaderboard can resolve names),
    // writable only by the owner of that profile.
    match /players/{playerId} {
      allow read: if true;
      allow create, update: if request.auth != null
        && request.auth.uid == playerId
        && request.resource.data.keys().hasOnly(['username', 'updatedAt'])
        && request.resource.data.username is string
        && request.resource.data.username.size() >= 3
        && request.resource.data.username.size() <= 24;
      allow delete: if false;
    }

    // Scripts — owner can read their own doc; writes go exclusively
    // through the saveScripts callable Function (which uses the Admin
    // SDK and bypasses these rules). This centralises validation and
    // makes future rate-limiting trivial to add.
    match /scripts/{playerId} {
      allow read: if request.auth != null && request.auth.uid == playerId;
      allow write: if false;
    }

    function isValidRanking() {
      return request.resource.data.keys().hasOnly([
          'id',
          'playerId',
          'username',
          'depth',
          'ticks',
          'insightEarned',
          'causeOfDeath',
          'finishedAt',
          'score',
          'submittedAt'
        ])
        && request.resource.data.id is string
        && request.resource.data.playerId is string
        && request.resource.data.username is string
        && request.resource.data.username.size() > 0
        && request.resource.data.username.size() <= 24
        && request.resource.data.depth is int
        && request.resource.data.depth >= 1
        && request.resource.data.depth <= 100000
        && request.resource.data.ticks is int
        && request.resource.data.ticks >= 0
        && request.resource.data.insightEarned is int
        && request.resource.data.insightEarned >= 0
        && request.resource.data.causeOfDeath is string
        && request.resource.data.causeOfDeath.size() <= 240
        && request.resource.data.finishedAt is string
        && request.resource.data.score is int
        && request.resource.data.score == request.resource.data.depth * 1000000 - request.resource.data.ticks;
    }
  }
}
