{
  "name": "functions",
  "private": true,
  "description": "Cloud Functions for autodelver",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc -w",
    "serve": "tsc && firebase emulators:start --only functions",
    "shell": "tsc && firebase functions:shell",
    "start": "tsc && firebase functions:shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "dependencies": {
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^6.1.0"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  }
}
